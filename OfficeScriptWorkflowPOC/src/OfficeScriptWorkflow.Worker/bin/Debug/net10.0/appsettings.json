{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Azure.Messaging.ServiceBus": "Warning",
        "OfficeScriptWorkflow": "Debug"
      }
    }
  },

  // ── Workbook registry ───────────────────────────────────────────────────────────
  // Each entry represents one workbook. Workbooks may be stored in:
  //   SharePoint (default)   — standard SharePoint document library on any site
  //   SharePointEmbedded     — SharePoint Embedded (SPE) app-owned container
  //
  // Each workbook has its own set of Power Automate flows because the "Run script"
  // action is hardcoded to a specific file at flow design time.
  // Flow URLs are SAS-signed secrets — store them in Azure Key Vault in production;
  // use dotnet user-secrets locally.
  //
  // Multiple replicas share this registry. Azure Service Bus sessions (SessionId = Id)
  // guarantee only one replica processes a given workbook at a time.
  "WorkbookRegistry": {
    "Workbooks": [

      // ── Example 1: Standard SharePoint site ──────────────────────────────────
      {
        "Id": "workbook-sp-01",
        "DisplayName": "Financials (SharePoint)",
        // StorageType defaults to "SharePoint" — field can be omitted.
        "StorageType": "SharePoint",
        "SiteUrl": "https://YOURTENANT.sharepoint.com/sites/Finance",
        "WorkbookPath": "/Shared Documents/Workbooks/Financials.xlsx",
        "BatchSize": 500,
        "InsertRangeFlowUrl": "",
        "UpdateRangeFlowUrl": "",
        "ExtractRangeFlowUrl": "",
        // BatchOperationFlowUrl replaces 40-50 individual calls with 1 call.
        // Leave empty if not using ExecuteBatchAsync().
        "BatchOperationFlowUrl": ""
      }

      // ── Example 2: SharePoint Embedded container ─────────────────────────────
      // Uncomment and configure when using SPE containers.
      // {
      //   "Id": "workbook-spe-01",
      //   "DisplayName": "Risk Model (SPE Container)",
      //   "StorageType": "SharePointEmbedded",
      //   // ContainerId: retrieve via Graph API GET /storage/fileStorage/containers
      //   // SiteUrl is derived from ContainerId:
      //   //   https://YOURTENANT.sharepoint.com/contentstorage/CSP_{ContainerId}
      //   "ContainerId": "b!xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      //   "ContainerTypeId": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
      //   "SiteUrl": "https://YOURTENANT.sharepoint.com/contentstorage/CSP_CONTAINERID",
      //   "WorkbookPath": "/Documents/RiskModel.xlsx",
      //   "BatchSize": 200,
      //   "InsertRangeFlowUrl": "",
      //   "UpdateRangeFlowUrl": "",
      //   "ExtractRangeFlowUrl": "",
      //   "BatchOperationFlowUrl": ""
      // }

      // ── Example 3: Second SharePoint site (different site from Example 1) ────
      // Each workbook can be on a completely different SharePoint site or SPE container.
      // {
      //   "Id": "workbook-sp-02",
      //   "DisplayName": "Operations (Different SharePoint Site)",
      //   "StorageType": "SharePoint",
      //   "SiteUrl": "https://YOURTENANT.sharepoint.com/sites/Operations",
      //   "WorkbookPath": "/Shared Documents/Reports/Operations.xlsx",
      //   "BatchSize": 500,
      //   "InsertRangeFlowUrl": "",
      //   "UpdateRangeFlowUrl": "",
      //   "ExtractRangeFlowUrl": ""
      // }

    ]
  },

  // ── Async polling & HTTP timeouts ───────────────────────────────────────────────
  // Processing model: one replica processes one workbook at a time, sequentially.
  // Parallel workbook processing is achieved by scaling replicas, not parallelism
  // within a single replica. See docs/multi-replica-deployment.md.
  "Concurrency": {
    // Per-attempt HTTP timeout (seconds). AsyncPollingHandler manages total wall-clock.
    "HttpTimeoutSeconds": 120,

    // Absolute cap on how long the 202 polling loop runs for one operation.
    // Office Scripts can run up to 5 min; set higher to allow for queuing time.
    "MaxPollingDurationMinutes": 10,

    // Fallback polling interval when Power Automate omits the Retry-After header.
    "DefaultPollingIntervalSeconds": 10
  },

  // ── Resilience ──────────────────────────────────────────────────────────────────
  "Resilience": {
    "RetryCount": 4,
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerBreakDurationSeconds": 30
  },

  // ── Flow account pool (high volume — secondary to batching) ────────────────────
  // Add accounts only when batch calls exceed 13,333/day (40,000 actions / 3 per call).
  // Each account holds its own set of Power Automate flows (M365 E3 + PA Premium).
  // Flow URLs for each account are stored in Key Vault (same naming convention as WorkbookRegistry).
  "FlowAccountPool": {
    "Accounts": []
    // Example (uncomment and configure when needed):
    // "Accounts": [
    //   {
    //     "AccountId": "svc-os-01",
    //     // Upn is used by scripts/Deploy-OfficeScripts.ps1 to deploy Office Scripts
    //     // to this account's OneDrive ("My Scripts"). Not used at runtime.
    //     "Upn": "svc-os-01@YOURTENANT.onmicrosoft.com",
    //     "DailyActionLimit": 36000,
    //     "InsertRangeFlowUrl": "",
    //     "UpdateRangeFlowUrl": "",
    //     "ExtractRangeFlowUrl": "",
    //     "BatchOperationFlowUrl": ""
    //   },
    //   {
    //     "AccountId": "svc-os-02",
    //     "Upn": "svc-os-02@YOURTENANT.onmicrosoft.com",
    //     "DailyActionLimit": 36000,
    //     "InsertRangeFlowUrl": "",
    //     "UpdateRangeFlowUrl": "",
    //     "ExtractRangeFlowUrl": "",
    //     "BatchOperationFlowUrl": ""
    //   }
    // ]
  },

  // ── Azure Service Bus (multi-replica) ───────────────────────────────────────────
  // Set UseServiceBus: true to switch from in-memory queue to Service Bus.
  // The queue MUST be session-enabled. SessionId = WorkbookId (see registry above).
  // ConnectionString should reference a Key Vault secret in production.
  "ServiceBus": {
    "UseServiceBus": false,
    "ConnectionString": "",
    "QueueName": "excel-operations",
    // One workbook per replica. Scale replicas to process more workbooks in parallel.
    "MaxConcurrentSessions": 1,
    "MessageLockDurationSeconds": 360
  }
}
