u0026os_version=12"}]},{"name":"gnutls28","SPDXID":"SPDXRef-Package-cf9b036973b92de2eb2337a516689960","versionInfo":"3.7.9-2+deb12u6","supplier":"Person: Debian GnuTLS Maintainers \\u003cpkg-gnutls-maint@lists.alioth.debian.org\\u003e","originator":"Person: Debian GnuTLS Maintainers \\u003cpkg-gnutls-maint@lists.alioth.debian.org\\u003e","downloadLocation":"NOASSERTION","filesAnalyzed":true,"licenseConcluded":"NOASSERTION","licenseDeclared":"Apache-2.0 OR BSD-3-Clause OR GFDL-1.3-only OR GPL-3.0-only OR LGPL-3.0-only","description":"GNU TLS library - main runtime library\n GnuTLS is a portable library which implements the Transport Layer\n Security (TLS 1.0, 1.1, 1.2, 1.3) and Datagram\n Transport Layer Security (DTLS 1.0, 1.2) protocols.\n .\n GnuTLS features support for:\n - certificate path validation, as well as DANE and trust on first use.\n - the Online Certificate Status Protocol (OCSP).\n - public key methods, including RSA and Elliptic curves, as well as password\n and key authentication methods such as SRP and PSK protocols.\n - all the strong encryption algorithms, including AES and Camellia.\n - CPU-assisted cryptography with VIA padlock and AES-NI instruction sets.\n - HSMs and cryptographic tokens, via PKCS #11.\n .\n This package contains the main runtime library.","externalRefs":[{"referenceCategory":"PACKAGE-MANAGER","referenceType":"purl","referenceLocator":"pkg:deb/debian/gnutls28@3.7.9-2%2Bdeb12u6?os_distro=bookworm\u0026os_name=debian\u0026os_version=12"}]},{"name":"gpgv","SPDXID":"SPDXRef-Package-6ec8a51316e19f1f0de485c061596d4f","versionInfo":"2.2.40-1.1+deb12u2","supplier":"Person: Debian GnuPG Maintainers \\u003cpkg-gnupg-maint@lists.alioth.debian.org\\u003e","originator":"Person: Debian GnuPG Maintainers \\u003cpkg-gnupg-maint@lists.alioth.debian.org\\u003e","downloadLocation":"NOASSERTION","filesAnalyzed":true,"licenseConcluded":"NOASSERTION","licenseDeclared":"BSD-3-Clause OR CC0-1.0 OR GPL-3.0-only OR GPL-3.0-or-later OR LGPL-2.1-only OR LGPL-2.1-or-later OR LGPL-3.0-only OR LGPL-3.0-or-later","description":"GNU privacy guard - signature verification tool\n GnuPG is GNU's tool for secure communication and data storage.\n .\n gpgv is actually a stripped-down version of gpg which is only able\n to check signatures. It is somewhat smaller than the fully-blown gpg\n and uses a different (and simpler) way to check that the public keys\n used to make the signature are valid. There are no configuration\n files and only a few options are implemented.","externalRefs":[{"referenceCategory":"PACKAGE-MANAGER","referenceType":"purl","referenceLocator":"pkg:deb/debian/gpgv@2.2.40-1.1%2Bdeb12u2?os_distro=bookworm\u0026os_name=debian\u0026os_version=12"}]},{"name":"grep","SPDXID":"SPDXRef-Package-e4edf29b14a545a831e0646c44ec81be","versionInfo":"3.8-5","supplier":"Person: Anibal Monsalve Salazar \\u003canibal@debian.org\\u003e","originator":"Person: Anibal Monsalve Salazar \\u003canibal@debian.org\\u003e","downloadLocation":"NOASSERTION","filesAnalyzed":true,"licenseConcluded":"NOASSERTION","licenseDeclared":"GPL-3.0-only OR GPL-3.0-or-later","description":"GNU grep, egrep and fgrep\n 'grep' is a utility to search for text in files; it can be used from the\n command line or in scripts.  Even if you don't want to use it, other packages\n on your system probably will.\n .\n The GNU family of grep utilities may be the \"fastest grep in the west\".\n GNU grep is based on a fast lazy-state deterministic matcher (about\n twice as fast as stock Unix egrep) hybridized with a Boyer-Moore-Gosper\n search for a fixed string that eliminates impossible text from being\n considered by the full regexp matcher without necessarily having to\n look at every character. The result is typically many times faster\n than Unix grep or egrep. (Regular expressions containing backreferencing\n will run more slowly, however.)","externalRefs":[{"referenceCategory":"PACKAGE-MANAGER","referenceType":"purl","referenceLocator":"pkg:deb/debian/grep@3.8-5?os_distro=bookworm\u0026os_name=debian\u0026os_version=12"}]},{"name":"gzip","SPDXID":"SPDXRef-Package-d5a05e6bd925e8cbe0cbc544294f7302","versionInfo":"1.12-1","supplier":"Person: Milan Kupcevic \\u003cmilan@debian.org\\u003e","originator":"Person: Milan Kupcevic \\u003cmilan@debian.org\\u003e","downloadLocation":"NOASSERTION","filesAnalyzed":true,"licenseConcluded":"NOASSERTION","licenseDeclared":"GPL-3.0-only OR GPL-3.0-or-later","description":"GNU compression utilities\n This package provides the standard GNU file compression utilities, which\n are also the default compression tools for Debian.  They typically operate\n on files with names ending in '.gz', but can also decompress files ending\n in '.Z' created with 'compress'.","externalRefs":[{"referenceCategory":"PACKAGE-MANAGER","referenceType":"purl","referenceLocator":"pkg:deb/debian/gzip@1.12-1?os_distro=bookworm\u0026os_name=debian\u0026os_version=12"}]},{"name":"hostname","SPDXID":"SPDXRef-Package-015fd954efbb0723c6e780d60f6a6905","versionInfo":"3.23+nmu1","supplier":"Person: Michael Meskes \\u003cmeskes@debian.org\\u003e","originator":"Person: Michael Meskes \\u003cmeskes@debian.org\\u003e","downloadLocation":"NOASSERTION","filesAnalyzed":true,"licenseConcluded":"NOASSERTION","licenseDeclared":"GPL-2.0-only","description":"utility to set/show the host name or domain name\n This package provides commands which can be used to display the system's\n DNS name, and to display or set its hostname or NIS domain name.","externalRefs":[{"referenceCategory":"PACKAGE-MANAGER","referenceType":"purl","referenceLocator":"pkg:deb/debian/hostname@3.23%2Bnmu1?os_distro=bookworm\u0026os_name=debian\u0026os_version=12"}]},{"name":"init-system-helpers","SPDXID":"SPDXRef-Package-a74b219b06c64c81915a8f3ece06eb51","versionInfo":"1.65.2+deb12u1","supplier":"Person: Debian systemd Maintainers \\u003cpkg-systemd-maintainers@lists.alioth.debian.org\\u003e","originator":"Person: Debian systemd Maintainers \\u003cpkg-systemd-maintainers@lists.alioth.debian.org\\u003e","downloadLocation":"NOASSERTION","filesAnalyzed":true,"licenseConcluded":"NOASSERTION","licenseDeclared":"BSD-3-Clause OR GPL-2.0-only OR GPL-2.0-or-later","description":"helper tools for all init systems\n This package contains helper tools that are necessary for switching between\n the various init systems that Debian contains (e. g. sysvinit or\n systemd). An example is deb-systemd-helper, a script that enables systemd unit\n files without depending on a running systemd.\n .\n It also includes the \"service\", \"invoke-rc.d\", and \"update-rc.d\" scripts which\n provide an abstraction for enabling, disabling, starting, and stopping\n services for all supported Debian init systems as specified by the policy.\n .\n While this package is maintained by pkg-systemd-maintainers, it is NOT\n specific to systemd at all. Maintainers of other init systems are welcome to\n include their helpers in this package.","externalRefs":[{"referenceCategory":"PACKAGE-MANAGER","referenceType":"purl","referenceLocator":"pkg:deb/debian/init-system-helpers@1.65.2%2Bdeb12u1?os_distro=bookworm\u0026os_name=debian\u0026os_version=12"}]},{"name":"libacl1","SPDXID":"SPDXRef-Package-ef447de7d634c5f5cfdf4eed88b07065","versionInfo":"2.3.1-3","supplier":"Person: Guillem Jover \\u003cguillem@debian.org\\u003e","originator":"Person: Guillem Jover \\u003cguillem@debian.org\\u003e","downloadLocation":"NOASSERTION","filesAnalyzed":true,"licenseConcluded":"NOASSERTION","licenseDeclared":"GPL-2.0-only OR GPL-2.0-or-later OR LGPL-2.0-or-later OR LGPL-2.1-only","description":"access control list - shared library\n This package contains the shared library containing the POSIX 1003.1e\n draft standard 17 functions for manipulating access control lists.","externalRefs":[{"referenceCategory":"PACKAGE-MANAGER","referenceType":"purl","referenceLocator":"pkg:deb/debian/libacl1@2.3.1-3?os_distro=bookworm\u0026os_name=debian\u0026os_version=12"}]},{"name":"libapt-pkg6.0"