    <tags>Microsoft Azure EventGrid Event Grid Event Grid Publishing</tags>
    <readme>README.md</readme>
    <repository type="git" url="https://github.com/Azure/azure-sdk-for-net" commit="c8be5482c55a42b3eb1ba7c9e75aa61bdfa13349" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Azure.Core" version="1.20.0" exclude="Build,Analyzers" />
        <dependency id="System.Memory.Data" version="1.0.2" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="4.6.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>