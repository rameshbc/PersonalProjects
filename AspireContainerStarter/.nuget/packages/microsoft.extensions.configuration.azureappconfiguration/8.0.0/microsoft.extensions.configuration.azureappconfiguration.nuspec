<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Microsoft.Extensions.Configuration.AzureAppConfiguration</id>
    <version>8.0.0</version>
    <authors>Microsoft</authors>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>https://github.com/Azure/AppConfiguration</projectUrl>
    <iconUrl>https://aka.ms/AzureAppConfigurationPackageIcon</iconUrl>
    <description>Microsoft.Extensions.Configuration.AzureAppConfiguration is a configuration provider for the .NET Core framework that allows developers to use Microsoft Azure App Configuration service as a configuration source in their applications.</description>
    <releaseNotes>https://aka.ms/MicrosoftExtensionsConfigurationAzureAppConfigurationReleaseNotes</releaseNotes>
    <copyright>© Microsoft Corporation. All rights reserved.</copyright>
    <tags>Microsoft Azure Configuration AppConfig AppConfiguration AzureAppConfiguration</tags>
