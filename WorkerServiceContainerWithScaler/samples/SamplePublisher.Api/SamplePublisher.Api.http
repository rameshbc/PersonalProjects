@host = http://localhost:5223

GET {{host}}/healthz
Accept: application/json

###

# Single order publish
POST {{host}}/orders
Content-Type: application/json

{
  "clientId": "client-001",
  "customerId": "cust-001",
  "amount": 99.99
}

###

# Batch publish — 20 orders (validates Service Bus SendMessagesAsync path)
POST {{host}}/orders/batch
Content-Type: application/json
X-Correlation-Id: 11111111-2222-3333-4444-555555555555

[
  { "clientId": "client-001", "customerId": "cust-001", "amount": 10.00 },
