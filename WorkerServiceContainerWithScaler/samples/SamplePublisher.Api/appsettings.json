{
  "Messaging": {
    "AuthMode": "ConnectionString",
    "ServiceName": "PublisherApi",
    "EnableCompression": true,
    "Audit": {
      "Enabled": true,
      "LogMessageBody": false,
      "PendingCheck": {
        "Enabled": true,
        "MaxPendingBeforeSuppress": 50,
        "LookbackWindowMinutes": 60
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  }
}
