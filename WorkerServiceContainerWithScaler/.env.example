# Copy this file to .env (gitignored) and fill in real values for local development.
# .env is loaded automatically by docker-compose.

# ── SQL Server ────────────────────────────────────────────────────────────────
# Strong password required by SQL Server (>= 8 chars, upper, lower, digit, symbol)
SA_PASSWORD=YourStr0ng!DevPass

# ── Azure Service Bus Emulator ────────────────────────────────────────────────
# Fixed emulator connection string — not a real secret, but kept here for consistency.
# UseDevelopmentEmulator=true tells the SDK to skip TLS and cert validation.
SERVICEBUS_EMULATOR_CONNECTION=Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE=;UseDevelopmentEmulator=true;

# ── App: SQL audit DB (injected into each service container) ──────────────────
# Built from SA_PASSWORD above in docker-compose.yml via variable substitution.
# When running apps locally (not in Docker), set this in user-secrets instead:
#   dotnet user-secrets set "ConnectionStrings:AuditDb" "Server=localhost,1433;..."
AUDIT_DB_CONNECTION=Server=localhost,1433;Database=MessagingAuditDev;User Id=sa;Password=YourStr0ng!DevPass;TrustServerCertificate=true;

# ── Production overrides (never set in .env — use AKS secrets / Key Vault) ───
# Messaging__AuthMode=ManagedIdentity
# Messaging__FullyQualifiedNamespace=your-ns.servicebus.windows.net
# ConnectionStrings__AuditDb=Server=your-server.database.windows.net;Database=MessagingAudit;Authentication=Active Directory Managed Identity;
