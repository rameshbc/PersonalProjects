# ── .NET / Visual Studio ──────────────────────────────────────────────────
## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build lock files
packages.lock.json
*.lock
paket.lock

# NuGet packages
*.nupkg
*.snupkg
.nuget/

# Local NuGet cache
~/.nuget/packages/

# dotnet user secrets
.user-secrets/
appsettings.local.json

# Application Insights telemetry
ApplicationInsights.config

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
TestResults/

# ── Azure & Deployment ─────────────────────────────────────────────────────
# Local bicep parameters with secrets
*.bicepparam
!*.bicepparam.template

# Local deployment scripts
deploy/scripts/*.local.ps1

# Azure credentials
.env
.env.local
.env.*.local
secrets.json
local.settings.json

# IaC state/locks
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json

# ── Docker ─────────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml
.docker/

# ── IDE & OS ───────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.swp
.swo

# ── Misc ───────────────────────────────────────────────────────────────────
# Temporary files
*.tmp
*.bak
*.swp
*.swo
*~

# Logs
*.log
logs/

# Coverage reports
coverage/
coverage.opencover.xml
coverage.cobertura.xml

# ReportGenerator files
reports/
