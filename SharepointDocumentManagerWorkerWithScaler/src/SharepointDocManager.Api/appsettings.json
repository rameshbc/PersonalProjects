{
  "Graph": {
    "AuthMode": "ManagedIdentity"
  },
  "Resilience": {
    "MaxConcurrentCallsPerClient": 4
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=#{SQL_SERVER}#;Database=SharepointDocManager;Authentication=Active Directory Managed Identity;TrustServerCertificate=True"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
