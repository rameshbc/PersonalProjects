# ── Development Environment Template ──────────────────────────────────────
# Copy this file to .env.local and fill in your values
# These variables are used by docker-compose.yml and appsettings.Development.json

# ── Microsoft Graph API Credentials ────────────────────────────────────────
# From: Azure Portal > App Registrations > Your App > Overview/Certificates
AZURE_TENANT_ID=your-entra-tenant-id
AZURE_CLIENT_ID=your-entra-app-registration-client-id
AZURE_CLIENT_SECRET=your-entra-app-registration-client-secret

# ── Authentication Mode ────────────────────────────────────────────────────
# Options: ManagedIdentity (prod), ClientCredentials (dev), Interactive (dev with browser)
GRAPH_AUTH_MODE=ClientCredentials

# ── SQL Server Configuration ───────────────────────────────────────────────
# Docker Compose provides these defaults; only change if using external SQL Server
SQL_SERVER=localhost,1433
SQL_DATABASE=SharepointDocManager
SQL_USERNAME=sa
SQL_PASSWORD=Dev_Password123!

# ── Application Insights (Optional) ────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── ASP.NET Core ───────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://+:8080

# ── Logging ────────────────────────────────────────────────────────────────
# Serilog minimum level: Debug, Information, Warning, Error
Serilog__MinimumLevel=Debug
